{
  "name": "hotel-pricing",
  "version": "1.0.0",
  "description": "Servicio automatizado para actualizar precios y disponibilidad de habitaciones",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "migrate:dev": "prisma migrate dev --name init",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "prisma",
    "cron",
    "axios",
    "hotel",
    "pricing"
  ],
  "author": "Diego Soba",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "axios": "^1.7.0",
    "axios-retry": "^3.9.1",
    "dotenv": "^16.6.1",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.0.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  }
}
